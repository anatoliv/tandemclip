<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.tandemclip</string>

    <!-- Default: the .app built by Scripts/make-app.sh and copied to
         /Applications. For a bare-binary install use /usr/local/bin/tandemclip.
         Add "--verbose" as a second <string> to trace discovery/TLS/sync. -->
    <key>ProgramArguments</key>
    <array>
        <string>/Applications/TandemClip.app/Contents/MacOS/tandemclip</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/tandemclip.out.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/tandemclip.err.log</string>
</dict>
</plist>
